{
  "id": "com.ekko.runninghub.ps",
  "name": "E_WinAI",
  "version": "0.1.1",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "PS",
    "minVersion": "25.0.0"
  },
  "requiredPermissions": {
    "network": {
      "domains": "all"
    },
    "localFileSystem": "request",
    "launchProcess": {
      "schemes": [
        "https"
      ]
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "runninghub-panel",
      "label": {
        "default": "E_WinAI"
      },
      "minimumSize": {
        "width": 320,
        "height": 420
      },
      "maximumSize": {
        "width": 800,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 640
      },
      "preferredFloatingSize": {
        "width": 380,
        "height": 680
      }
    }
  ]
}
